# CtxOS User Zsh Configuration
# Copy this to ~/.zshrc and customize

# Source global CtxOS config
if [ -f /etc/zsh/zshrc ]; then
    source /etc/zsh/zshrc
fi

# User customizations
# Add your aliases, functions, and prompt below

# Custom prompt example:
# PS1="%F{cyan}%n@CtxOS%f:%F{yellow}%~%f%# "

# Custom aliases
# alias myalias='command'

# Load completion for additional tools
# autoload -U zsh-mime-setup
