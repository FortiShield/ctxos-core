#!/bin/bash
# CTX OS Release Archiver
# Archives release artifacts (deb, changes, buildinfo, dsc) for a given version.
set -euo pipefail

ARCHIVE_DIR="${CTXOS_ARCHIVE_DIR:-/var/lib/ctxos/archive}"
PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

VERSION="${1:-$(cd "$PROJECT_ROOT" && dpkg-parsechangelog -S Version)}"
TIMESTAMP="$(date '+%Y%m%d-%H%M%S')"
RELEASE_NAME="ctxos-core-${VERSION}"
ARCHIVE_NAME="${RELEASE_NAME}-${TIMESTAMP}"
ARCHIVE_PATH="${ARCHIVE_DIR}/${ARCHIVE_NAME}"

usage() {
    echo "Usage: $(basename "$0") [VERSION]"
    echo ""
    echo "Archive release artifacts for ctxos-core."
    echo ""
    echo "If VERSION is omitted, it is read from debian/changelog."
    echo ""
    echo "Environment variables:"
    echo "  CTXOS_ARCHIVE_DIR  Archive destination (default: /var/lib/ctxos/archive)"
    exit 1
}

if [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    usage
fi

echo "============================================"
echo "  CTX OS Release Archiver"
echo "============================================"
echo ""
echo "Version:   $VERSION"
echo "Archive:   $ARCHIVE_NAME"

# Locate build artifacts
SRC_DIR="$PROJECT_ROOT/.."
DEB_FILES=("$SRC_DIR"/ctxos-core"${VERSION}"*_all.deb)
CHANGES_FILE="$SRC_DIR/ctxos-core_${VERSION}_amd64.changes"
BUILDINFO_FILE="$SRC_DIR/ctxos-core_${VERSION}_amd64.buildinfo"
DSC_FILE="$SRC_DIR/ctxos-core_${VERSION}.dsc"
TAR_FILE="$SRC_DIR/ctxos-core_${VERSION}.tar.gz"

FOUND=0
for f in "${DEB_FILES[@]}"; do
    if [ -f "$f" ]; then
        FOUND=1
        break
    fi
done
if [ -f "$CHANGES_FILE" ] || [ -f "$BUILDINFO_FILE" ] || [ -f "$DSC_FILE" ] || [ -f "$TAR_FILE" ]; then
    FOUND=1
fi

if [ "$FOUND" -eq 0 ]; then
    echo "ERROR: No release artifacts found for version ${VERSION}."
    echo "Run 'bin/build.sh' first to produce the .deb and related files."
    exit 1
fi

# Create archive directory
mkdir -p "$ARCHIVE_PATH"

# Copy artifacts
echo ""
echo "📦 Copying artifacts..."
for f in "${DEB_FILES[@]}"; do
    if [ -f "$f" ]; then
        cp "$f" "$ARCHIVE_PATH/"
        echo "  $(basename "$f")"
    fi
done
for f in "$CHANGES_FILE" "$BUILDINFO_FILE" "$DSC_FILE" "$TAR_FILE"; do
    if [ -f "$f" ]; then
        cp "$f" "$ARCHIVE_PATH/"
        echo "  $(basename "$f")"
    fi
done

# Record metadata
cat > "$ARCHIVE_PATH/METADATA" <<EOF
package=ctxos-core
version=${VERSION}
timestamp=${TIMESTAMP}
hostname=$(hostname 2>/dev/null || echo "unknown")
builder=$(whoami)
git_commit=$(cd "$PROJECT_ROOT" && git rev-parse --short HEAD 2>/dev/null || echo "unknown")
git_branch=$(cd "$PROJECT_ROOT" && git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
EOF
echo "  METADATA"

# Create compressed tarball of the archive
echo ""
echo "🗜️ Creating tarball..."
TARBALL="${ARCHIVE_DIR}/${ARCHIVE_NAME}.tar.gz"
tar -czf "$TARBALL" -C "$ARCHIVE_DIR" "$ARCHIVE_NAME"
rm -rf "$ARCHIVE_PATH"

echo ""
echo "✅ Release archived: $TARBALL"
echo ""
echo "To extract later:"
echo "  tar -xzf $TARBALL -C /tmp/"
echo ""
