#!/bin/bash
# CTX OS Developer Setup Script
set -euo pipefail

echo "============================================"
echo "  CTX OS Developer Environment Setup"
echo "============================================"

# 1. Install Common Development Tools
echo "📦 Installing development tools..."

if command -v apt-get &> /dev/null; then
    sudo apt-get update -qq
    sudo apt-get install -y -qq \
        build-essential \
        curl \
        wget \
        git \
        vim \
        htop \
        tree \
        unzip \
        zip \
        jq \
        software-properties-common \
        apt-transport-https \
        ca-certificates \
        gnupg \
        lsb-release || true
fi

# 2. Install Docker (if not present)
if ! command -v docker &> /dev/null; then
    echo "🐳 Setting up Docker..."
    if command -v apt-get &> /dev/null; then
        curl -fsSL -o /tmp/docker.gpg https://download.docker.com/linux/debian/gpg
        sudo gpg --dearmor -o /usr/share/keyrings/docker-archive-keyring.gpg /tmp/docker.gpg
        echo "deb [arch=amd64 signed-by=/usr/share/keyrings/docker-archive-keyring.gpg] https://download.docker.com/linux/debian $(lsb_release -cs) stable" | sudo tee /etc/apt/sources.list.d/docker.list > /dev/null
        sudo apt-get update -qq
        sudo apt-get install -y -qq docker-ce docker-ce-cli containerd.io docker-compose-plugin
        rm -f /tmp/docker.gpg
    fi
fi

# 3. Install Node.js (LTS)
if ! command -v node &> /dev/null; then
    echo "🟢 Setting up Node.js..."
    if command -v apt-get &> /dev/null; then
        curl -fsSL -o /tmp/nodesource-setup.sh https://deb.nodesource.com/setup_lts.x
        sudo -E bash /tmp/nodesource-setup.sh
        sudo apt-get install -y -qq nodejs
        rm -f /tmp/nodesource-setup.sh
    fi
fi

# 4. Install Visual Studio Code (if on Debian/Ubuntu)
if ! command -v code &> /dev/null; then
    echo "💻 Setting up VS Code..."
    if command -v apt-get &> /dev/null; then
        curl -fsSL -o /tmp/vscode.gpg https://packages.microsoft.com/keys/microsoft.asc
        sudo gpg --dearmor -o /usr/share/keyrings/packages-microsoft-keyring.gpg /tmp/vscode.gpg
        echo "deb [arch=amd64 signed-by=/usr/share/keyrings/packages-microsoft-keyring.gpg] https://packages.microsoft.com/repos/code stable main" | sudo tee /etc/apt/sources.list.d/vscode.list > /dev/null
        sudo apt-get update -qq
        sudo apt-get install -y -qq code
        rm -f /tmp/vscode.gpg
    fi
fi

# 5. Install Python Development
echo "🐍 Setting up Python development..."
if command -v apt-get &> /dev/null; then
    sudo apt-get install -y -qq \
        python3 \
        python3-pip \
        python3-venv \
        python3-dev \
        python3-setuptools
fi

# 6. Local HTTPS Development (SSL)
echo "🔐 Setting up Local Development CA..."

CERT_DIR="$HOME/.ctxos/certs"
mkdir -p "$CERT_DIR"
cd "$CERT_DIR"

if [ ! -f "ctxos-rootCA.key" ]; then
    openssl genrsa -out ctxos-rootCA.key 4096

    openssl req -x509 -new -nodes -key ctxos-rootCA.key -sha256 -days 3650 \
        -config /etc/ssl/openssl.cnf \
        -subj "/C=US/ST=CTX-State/L=CTX-City/O=CTX OS Project/CN=CTX-Dev-Root-CA" \
        -out ctxos-rootCA.pem

    sudo cp ctxos-rootCA.pem /usr/local/share/ca-certificates/ctxos-rootCA.crt
    sudo update-ca-certificates

    echo "✅ Local CA installed. Your system now trusts certificates signed by CTX OS."
else
    echo "ℹ️ Local CA already exists. Skipping generation."
fi

# Create localhost certificate
if [ ! -f "localhost.crt" ]; then
    echo "Creating localhost certificate..."
    openssl req -new -nodes -out localhost.csr -newkey rsa:4096 \
        -keyout localhost.key \
        -subj "/C=US/ST=CTX-State/L=CTX-City/O=CTX OS Project/CN=localhost"

    openssl x509 -req -in localhost.csr -CA ctxos-rootCA.pem -CAkey ctxos-rootCA.key \
        -CAcreateserial -out localhost.crt -days 365 -sha256

    rm -f localhost.csr
    echo "✅ localhost certificate created in $CERT_DIR"
fi

echo ""
echo "============================================"
echo "✅ Developer Environment Setup Complete!"
echo "============================================"
echo ""
echo "📁 Local CA certificates: $CERT_DIR"
echo "   - ctxos-rootCA.pem (Root CA)"
echo "   - localhost.crt (Localhost cert)"
echo ""
echo "Run 'ctx-about' to see system info"
