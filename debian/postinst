#!/bin/sh
set -e

case "$1" in
    configure)
        mkdir -p /etc/ctxos
        
        if [ ! -d /home/public ]; then
            mkdir -p /home/public
            chmod 777 /home/public
        fi
        
        systemctl daemon-reload 2>/dev/null || true
        systemctl enable ctxos-dns.service 2>/dev/null || true
        
        if [ -x "/etc/init.d/smbd" ] || [ -x "/usr/sbin/smbd" ]; then
            systemctl restart smbd 2>/dev/null || true
            systemctl restart nmbd 2>/dev/null || true
        fi
        
        if [ -d /etc/postgresql ]; then
            for conf in /etc/postgresql/*/main/postgresql.conf; do
                if [ -f "$conf" ] && ! grep -q "ctx_postgresql.conf" "$conf"; then
                    echo "include = '/etc/postgresql/ctx_postgresql.conf'" >> "$conf"
                fi
            done
            if id -u postgres >/dev/null 2>&1; then
                chown postgres:postgres /etc/postgresql/ctx_postgresql.conf 2>/dev/null || true
                chown postgres:postgres /etc/postgresql/postgresql_reduce_shared_buffers 2>/dev/null || true
                chmod 644 /etc/postgresql/ctx_postgresql.conf 2>/dev/null || true
            fi
            systemctl restart postgresql 2>/dev/null || true
        fi
        
        if [ -x "/usr/sbin/xrdp" ] || [ -x "/usr/sbin/xrdp-sesman" ]; then
            systemctl restart xrdp 2>/dev/null || true
            systemctl restart xrdp-sesman 2>/dev/null || true
        fi
        ;;
    abort-upgrade|abort-remove|abort-deconfigure)
        ;;
    *)
        exit 1
        ;;
esac

exit 0
