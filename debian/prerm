#!/bin/sh
set -e

case "$1" in
    remove|purge)
        systemctl disable ctxos-dns.service 2>/dev/null || true
        systemctl stop ctxos-dns.service 2>/dev/null || true
        ;;
    upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        ;;
    *)
        exit 1
        ;;
esac

exit 0
