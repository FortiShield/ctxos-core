#!/bin/sh
set -e

CTXOS_DIVERT_LIST="
/etc/os-release
/etc/lsb-release
/etc/issue
/etc/issue.net
/etc/motd
"

case "$1" in
    remove)
        echo "Removing CtxOS..."
        ;;
    purge)
        echo "Purging CtxOS..."
        rm -rf /etc/ctxos 2>/dev/null || true
        rm -f /var/log/ctx-update.log 2>/dev/null || true
        for file in $CTXOS_DIVERT_LIST; do
            dpkg-divert --remove --rename --package ctxos "$file" 2>/dev/null || true
        done
        ;;
    upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        ;;
    *)
        exit 1
        ;;
esac

exit 0
